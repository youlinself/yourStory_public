{
  "version": 1,
  "commands": [
    {
      "id": "observe",
      "slash": "观察",
      "aliases": ["look", "查"],
      "args": [
        {
          "name": "target",
          "required": false,
          "placeholder": "目标",
          "completer": "generic_target"
        }
      ],
      "defaults": {
        "target": "周围环境"
      },
      "template": "我仔细观察{target}，注意环境中的细节、声响与可疑之处。"
    },
    {
      "id": "talk",
      "slash": "对话",
      "aliases": ["talk", "搭话"],
      "args": [
        {
          "name": "npc",
          "required": true,
          "resolver": "nearby_npc",
          "placeholder": "附近的人"
        },
        {
          "name": "message",
          "required": false,
          "placeholder": "想说什么"
        }
      ],
      "defaults": {
        "message": ""
      },
      "template": "我找到{npc_name}，{message_part}"
    },
    {
      "id": "skill",
      "slash": "技能",
      "aliases": ["skill", "use"],
      "args": [
        {
          "name": "skill",
          "required": true,
          "resolver": "protagonist_skill",
          "placeholder": "技能名"
        },
        {
          "name": "detail",
          "required": false,
          "placeholder": "具体怎么做"
        }
      ],
      "defaults": {
        "detail": ""
      },
      "template": "我尝试运用「{skill_name}」{detail}。"
    },
    {
      "id": "move",
      "slash": "前往",
      "aliases": ["go", "move"],
      "args": [
        {
          "name": "region",
          "required": true,
          "resolver": "unlocked_region",
          "placeholder": "地点"
        },
        {
          "name": "detail",
          "required": false,
          "placeholder": "途中怎么做"
        }
      ],
      "defaults": {
        "detail": ""
      },
      "template": "我决定前往{region_name}{detail_part}。"
    },
    {
      "id": "inventory",
      "slash": "整理",
      "aliases": ["pack", "背包"],
      "args": [],
      "template": "我停下来整理随身装备与背包，确认物资是否齐全、有无损耗。"
    },
    {
      "id": "wait",
      "slash": "等待",
      "aliases": ["wait", "歇"],
      "args": [
        {
          "name": "duration",
          "required": false,
          "placeholder": "多久",
          "completer": "duration_hints"
        }
      ],
      "defaults": {
        "duration": "片刻"
      },
      "template": "我选择等待{duration}，观察周遭动静，不轻易暴露自己的意图。"
    }
  ]
}
