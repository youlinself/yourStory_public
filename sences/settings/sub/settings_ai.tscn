[node name="AuthPrefixLabel" type="Label" parent="."]
layout_mode = 2
text = "认证前缀"
horizontal_alignment = 1

[node name="AuthPrefixInput" type="LineEdit" parent="."]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "如 Bearer （含空格）或留空"
unique_name_in_owner = true

[node name="APIKeyLabel" type="Label" parent="."]
layout_mode = 2
text = "API Key"
horizontal_alignment = 1

[node name="APIKeyRow" type="HBoxContainer" parent="."]
