[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/settings/sub/settings_ai.gd" id="1"]

[node name="AISettings" type="VBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 14
script = ExtResource("1")

[node name="TopPad" type="Control" parent="."]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="TitleLabel" type="Label" parent="."]
layout_mode = 2
text = "AI 设置"
theme_override_font_sizes/font_size = 32
horizontal_alignment = 1

[node name="VendorLabel" type="Label" parent="."]
layout_mode = 2
text = "模型厂商"
horizontal_alignment = 1

[node name="VendorOption" type="OptionButton" parent="."]
layout_mode = 2
size_flags_horizontal = 3
unique_name_in_owner = true

[node name="ConnectionLabel" type="Label" parent="."]
layout_mode = 2
text = "连接配置"
theme_override_font_sizes/font_size = 20
horizontal_alignment = 1

[node name="WebsiteLabel" type="Label" parent="."]
layout_mode = 2
text = "API Base URL"
horizontal_alignment = 1

[node name="WebsiteInput" type="LineEdit" parent="."]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "不含 /v1，如 https://api.xiaomimimo.com"
unique_name_in_owner = true

[node name="ModelsUrlLabel" type="Label" parent="."]
layout_mode = 2
text = "模型列表 URL"
horizontal_alignment = 1

[node name="ModelsUrlInput" type="LineEdit" parent="."]
layout_mode = 2
size_flags_horizontal = 3
