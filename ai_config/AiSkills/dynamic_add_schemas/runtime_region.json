{
  "schema_id": "runtime_region",
  "version": 1,
  "display_name": "运行时区域",
  "description": "剧情中首次出现的城区/片区，写入地图 regions 并解锁导航。",
  "when_to_use": [
    "全新城区、郊区片名",
    "玩家将获得地图知识的新大区"
  ],
  "target": {
    "db_file": "map_db.json",
    "storage_kind": "map_array",
    "map_structure_key": "regions",
    "record_key_field": "id"
  },
  "reuse_config_path": "res://src/novel_config/config/regionConfig.json",
  "prompt_compact": {
    "id": "",
    "name": "",
    "location": "",
    "terrain": "",
    "climate": "",
    "resources": "",
    "hazards": "",
    "access": "",
    "settlements": "",
    "adjacent_region_ids": []
  },
  "dedupe": {
    "fields": ["id", "name"],
    "case_insensitive_name": true
  },
  "generation_rules": [
    "id 使用 snake_case，如 region_south_suburbs",
    "adjacent_region_ids 至少包含一个与当前剧情相关的已有区域 id",
    "入库后程序会自动加入 unlocked_region_ids"
  ]
}
