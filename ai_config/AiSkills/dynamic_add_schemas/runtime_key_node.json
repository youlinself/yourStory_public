{
  "schema_id": "runtime_key_node",
  "version": 1,
  "display_name": "运行时子地点",
  "description": "剧情中首次出现的具体场所（小区、楼栋、店铺等），挂到已有区域。",
  "when_to_use": [
    "新小区、门牌、楼栋、店铺",
    "会在多轮复现的具体地址"
  ],
  "target": {
    "db_file": "map_db.json",
    "storage_kind": "map_array",
    "map_structure_key": "key_nodes",
    "record_key_field": "id"
  },
  "reuse_config_path": "res://src/novel_config/config/keyNodeConfig.json",
  "prompt_compact": {
    "id": "",
    "name": "",
    "type": "地标",
    "description": "",
    "region_id": ""
  },
  "dedupe": {
    "fields": ["id", "name"],
    "case_insensitive_name": true
  },
  "generation_rules": [
    "id 使用 snake_case，如 node_kangning_501",
    "region_id 必须是 map_db 中已有区域 id；若属全新城区须先 DYN_ADD 区域",
    "name 为玩家可见短名（如康宁小区7栋501）"
  ]
}
