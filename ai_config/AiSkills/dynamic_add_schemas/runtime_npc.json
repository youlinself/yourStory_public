{
  "schema_id": "runtime_npc",
  "version": 1,
  "display_name": "运行时 NPC",
  "description": "游戏中首次遭遇、未在 world_init_setting 中定义的 NPC。",
  "when_to_use": [
    "探索区域遇到新角色",
    "随机遭遇、临时商人、路人"
  ],
  "target": {
    "db_file": "npc_db.json",
    "envelope_key": "npcs",
    "record_key_field": "id"
  },
  "reuse_config_path": "res://src/novel_config/config/characterConfig.json",
  "prompt_compact": {
    "id": "",
    "name": "",
    "age": 0,
    "性别": "",
    "族群": "",
    "origin": "",
    "cleanliness_score": 50,
    "physical_traits": "",
    "equipment": [],
    "skills": [],
    "items": [],
    "abilities": {
      "str": 50,
      "agi": 50,
      "con": 50,
      "int": 50,
      "mnd": 50,
      "cha": 50
    },
    "psychology": {
      "openness": 50,
      "conscientiousness": 50,
      "extraversion": 50,
      "agreeableness": 50,
      "neuroticism": 50
    },
    "personality": "",
    "deep_motivation": "",
    "core_conflict": "",
    "current_region_id": "",
    "current_key_node_id": "",
    "initial_scene": "",
    "character_arc": "",
    "relationships": {
      "potential_allies": [],
      "enemy_npcs": [],
      "enemy_factions": []
    }
  },
  "dedupe": {
    "fields": ["id", "name"],
    "case_insensitive_name": true
  },
  "input_hints": {
    "role": "string，如商人、猎人、难民",
    "faction_hint": "string，可选势力 id"
  },
  "output": {
    "data": "字段定义见 reuse_config_path，生成时填满 prompt_compact"
  },
  "generation_rules": [
    "结构对齐 characterConfig.json（生成轮由程序注入），勿添加 schema 外顶层字段",
    "abilities、psychology 各子项均为 0-100 整数，须与角色设定、职业与 personality 描述一致",
    "skills 数组引用已有技能 id；items 引用已有物品/武器 id，缺失时可先 dynamic_add 再引用",
    "运行时 NPC 的 initial_scene 描述当前遭遇即可，不必重写整个世界观"
  ],
  "example": {
    "request": {
      "skill": "dynamic_add",
      "params": {
        "schema_id": "runtime_npc",
        "hints": {
          "role": "流浪商人"
        },
        "source_context": "断桥集市"
      }
    },
    "response": {
      "status": "new_created",
      "schema_id": "runtime_npc",
      "data": {
        "id": "npc_bridge_market_trader_01",
        "name": "铁壳老周",
        "age": 52,
        "性别": "男",
        "族群": "汉族",
        "origin": "前聚落修理工，现独行商贩",
        "cleanliness_score": 40,
        "physical_traits": "左臂义肢锈迹斑斑，嗓音沙哑",
        "equipment": ["破旧防毒面具"],
        "skills": ["skill_barter", "skill_scavenge"],
        "items": [],
        "abilities": {
          "str": 42,
          "agi": 48,
          "con": 55,
          "int": 58,
          "mnd": 52,
          "cha": 61
        },
        "psychology": {
          "openness": 38,
          "conscientiousness": 72,
          "extraversion": 35,
          "agreeableness": 40,
          "neuroticism": 45
        },
        "personality": "精明寡言，见钱眼开但不多嘴",
        "deep_motivation": "攒够路费回东部聚落",
        "core_conflict": "利润 vs 对熟客的同情",
        "initial_scene": "断桥集市帐篷下，黑雨刚停",
        "character_arc": "可能发展为固定商人或一次性过客",
        "relationships": {
          "potential_allies": [],
          "enemy_npcs": [],
          "enemy_factions": []
        }
      },
      "storage_note": "已存入 npc_db.json → npcs['npc_bridge_market_trader_01']"
    }
  }
}
