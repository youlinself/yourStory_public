{
  "version": 2,
  "skill_name": "dynamic_add",
  "loading_policy": {
    "system_prompt": ["DynamicAddService.build_skill_registration_prompt() 或 dynamic_add_registry.json"],
    "on_trigger": "AI 输出 [[DYN_ADD:分类|来源]] 后，程序仅加载对应一个 schema 并发起生成轮",
    "do_not_send_to_ai_by_default": ["各 schema 的 example", "dynamic_add.md 全文", "未选中的 schema 文件"]
  },
  "trigger_format": "[[DYN_ADD:{category}|{source_context}]]",
  "schemas_dir": "ai_config/AiSkills/dynamic_add_schemas",
  "schemas": [
    {
      "schema_id": "loot_item",
      "file": "loot_item.json",
      "display_name": "运行时物品（非装备）",
      "target_db": "items_db.json",
      "summary": "消耗品、材料、货币、垃圾等，写入 items 表",
      "when_to_use": ["翻找废墟、掉落材料", "NPC 赠送消耗品", "交易普通道具"]
    },
    {
      "schema_id": "loot_weapon",
      "file": "loot_weapon.json",
      "display_name": "运行时武器/装备",
      "target_db": "weapon_db.json",
      "summary": "可穿戴武器、护甲、工具等，写入 weapons 表",
      "when_to_use": ["废墟装备", "敌人掉落武器护甲", "锻造或奖励装备"]
    },
    {
      "schema_id": "runtime_skill",
      "file": "runtime_skill.json",
      "display_name": "运行时技能",
      "target_db": "skills_db.json",
      "summary": "剧情或探索解锁的新技能",
      "when_to_use": ["学会新技能", "任务奖励能力"],
      "reuse_config_path": "res://src/novel_config/config/skillConfig.json"
    },
    {
      "schema_id": "runtime_npc",
      "file": "runtime_npc.json",
      "display_name": "运行时 NPC",
      "target_db": "npc_db.json",
      "summary": "遭遇未在世界初始化中定义的 NPC",
      "when_to_use": ["探索遭遇新角色", "随机商人或路人"],
      "reuse_config_path": "res://src/novel_config/config/characterConfig.json"
    },
    {
      "schema_id": "runtime_key_node",
      "file": "runtime_key_node.json",
      "display_name": "运行时子地点",
      "target_db": "map_db.json",
      "summary": "具体场所写入 map_structure.key_nodes",
      "when_to_use": ["新小区、楼栋、店铺"],
      "reuse_config_path": "res://src/novel_config/config/keyNodeConfig.json"
    },
    {
      "schema_id": "runtime_region",
      "file": "runtime_region.json",
      "display_name": "运行时区域",
      "target_db": "map_db.json",
      "summary": "新城区写入 map_structure.regions",
      "when_to_use": ["全新城区、郊区片名"],
      "reuse_config_path": "res://src/novel_config/config/regionConfig.json"
    }
  ]
}
